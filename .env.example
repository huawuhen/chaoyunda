# ------------------------------------------------------------
# App server
# ------------------------------------------------------------
# Express service port. Docker Compose maps this port to the host.
PORT=4173

# ------------------------------------------------------------
# Model APIs
# ------------------------------------------------------------
# TkHub video generation API.
TKHUB_API_BASE_URL=https://api.tkhub.ai
TKHUB_API_KEY=replace-with-your-tkhub-api-key

# MuAPI text-to-video and image-to-video API.
MUAPI_BASE_URL=https://api.muapi.ai/api/v1
MUAPI_API_KEY=replace-with-your-muapi-api-key

# Upstream model API network settings.
UPSTREAM_CONNECT_TIMEOUT_MS=30000
UPSTREAM_REQUEST_TIMEOUT_MS=60000
UPSTREAM_FETCH_RETRIES=1
UPSTREAM_LOG_VERBOSE=0

# ------------------------------------------------------------
# Upload storage: S3-compatible object storage
# ------------------------------------------------------------
# Volcengine TOS example:
#   S3_ENDPOINT=https://tos-s3-ap-southeast-3.volces.com
#   S3_REGION=ap-southeast-3
#   S3_FORCE_PATH_STYLE=false
#
# Important:
# - Use a full URL with https:// for the Node AWS SDK endpoint.
# - Volcengine TOS S3 endpoints should use virtual-host style, so keep
#   S3_FORCE_PATH_STYLE=false.
S3_ENDPOINT=https://tos-s3-ap-southeast-3.volces.com
S3_BUCKET=redith-assets
S3_REGION=ap-southeast-3
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=replace-with-your-s3-access-key-id
S3_SECRET_ACCESS_KEY=replace-with-your-s3-secret-access-key
S3_SIGNED_URL_EXPIRES_SECONDS=604800

# Local upload size limit in MB. Keep Nginx client_max_body_size aligned.
MAX_UPLOAD_MB=200

# ------------------------------------------------------------
# Legacy image host upload config. Keep disabled unless switching /api/upload
# back from S3 to the image hosting service.
# ------------------------------------------------------------
# IMAGE_HOST_BASE_URL=https://tuchuang.huawuhen.online
# IMAGE_HOST_UPLOAD_URL=https://tuchuang.huawuhen.online/upload
